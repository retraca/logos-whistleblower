{
  "version": "0.1.0",
  "name": "cid_registry_program",
  "instructions": [
    {
      "name": "initialize",
      "accounts": [
        {
          "name": "registry",
          "writable": true,
          "signer": false,
          "init": true,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "value": "registry_state"
              }
            ]
          }
        },
        {
          "name": "authority",
          "writable": false,
          "signer": true,
          "init": false
        }
      ],
      "args": []
    },
    {
      "name": "anchor_batch",
      "accounts": [
        {
          "name": "registry",
          "writable": true,
          "signer": false,
          "init": false,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "value": "registry_state"
              }
            ]
          }
        }
      ],
      "args": [
        {
          "name": "entries_cids",
          "type": {
            "vec": {
              "vec": "u8"
            }
          }
        },
        {
          "name": "entries_meta_hashes",
          "type": {
            "vec": {
              "array": [
                "u8",
                32
              ]
            }
          }
        },
        {
          "name": "entries_timestamps",
          "type": {
            "vec": "u64"
          }
        }
      ]
    }
  ],
  "accounts": [
    {
      "name": "RegistryState",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "records",
            "type": { "vec": { "defined": "DocumentRecord" } }
          }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "DocumentRecord",
      "kind": "struct",
      "fields": [
        { "name": "cid", "type": { "array": ["u8", 46] } },
        { "name": "metadata_hash", "type": { "array": ["u8", 32] } },
        { "name": "anchor_timestamp", "type": "u64" }
      ]
    }
  ]
}
